{
  "name": "simple-admin",
  "private": true,
  "author": "SongPeng",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build  --mode production",
    "build:test": "vue-tsc --noEmit --skipLibCheck && vite build --mode test",
    "preview": "vite preview --open --port 9999",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint src --fix ",
    "lint-staged": "lint-staged --no-stash"
  },
  "dependencies": {
    "@alova/scene-vue": "^1.5.0",
    "@iconify/utils": "^2.1.23",
    "@vueuse/components": "^10.10.0",
    "@vueuse/core": "^10.10.0",
    "@vueuse/motion": "^2.1.0",
    "alova": "^2.20.5",
    "ant-design-vue": "^4.2.1",
    "dayjs": "^1.11.11",
    "echarts": "^5.5.0",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "print-js": "^1.6.0",
    "qs": "^6.12.1",
    "store2": "^2.14.3",
    "vue": "^3.4.27",
    "vue-draggable-plus": "^0.4.1",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@faker-js/faker": "^8.4.1",
    "@iconify/json": "^2.2.214",
    "@iconify/vue": "^4.1.2",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.12.12",
    "@types/nprogress": "^0.2.3",
    "@unocss/preset-icons": "0.60.3",
    "@unocss/transformer-directives": "^0.60.3",
    "@vitejs/plugin-legacy": "^5.4.0",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "eslint": "^9.3.0",
    "eslint-plugin-vue": "^9.26.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "sass": "^1.77.2",
    "terser": "^5.31.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.11.0",
    "unocss": "^0.60.3",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.2.12",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-fake-server": "^2.1.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pwa": "^0.19.8",
    "vue-eslint-parser": "^9.4.2",
    "vue-tsc": "^2.0.19"
  },
  "lint-staged": {
    "*.{vue,js,ts,tsx,jsx}": [
      "eslint src --fix",
      "git add"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.1.0"
  }
}
