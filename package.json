{
  "name": "simple-admin",
  "private": true,
  "author": "SongPeng",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite --open",
    "build:prod": "vue-tsc --noEmit --skipLibCheck && vite build  --mode production",
    "build:test": "vue-tsc --noEmit --skipLibCheck && vite build --mode test",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint src --fix --ext .ts,.tsx,.vue,.js,.jsx",
    "preview": "vite preview --open --port 9999",
    "lint-staged": "lint-staged --no-stash",
    "commit": "git cz",
    "add-commit": "git add . && git cz"
  },
  "dependencies": {
    "@alova/scene-vue": "^1.4.5",
    "@vueuse/components": "^10.7.2",
    "@vueuse/core": "^10.9.0",
    "alova": "^2.18.0",
    "ant-design-vue": "^4.1.2",
    "echarts": "^5.4.3",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "print-js": "^1.6.0",
    "qs": "^6.11.2",
    "store2": "^2.14.2",
    "vue": "^3.4.21",
    "vue-draggable-plus": "^0.3.5",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@faker-js/faker": "^8.4.1",
    "@iconify/json": "^2.2.173",
    "@iconify/vue": "^4.1.1",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.7",
    "@types/node": "^20.2.3",
    "@types/nprogress": "^0.2.0",
    "@types/sortablejs": "^1.15.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-legacy": "^5.3.2",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "autoprefixer": "^10.4.16",
    "commitizen": "^4.3.0",
    "cz-git": "^1.8.0",
    "eslint": "^8.56.0",
    "eslint-define-config": "^2.0.0",
    "eslint-plugin-vue": "^9.19.2",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.33",
    "sass": "^1.70.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.27.0",
    "typescript": "^5.3.3",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-icons": "^0.18.2",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.6",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-fake-server": "^2.1.1",
    "vite-plugin-html": "^3.2.1",
    "vite-plugin-pwa": "^0.17.4",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.0.6"
  },
  "lint-staged": {
    "*.{vue,js,ts,tsx,jsx}": [
      "eslint --fix",
      "git add"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "packageManager": "pnpm@8.1.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.1.0"
  }
}
