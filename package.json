{
  "name": "simple-admin",
  "private": true,
  "author": "SongPeng",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "dev:test": "vite --open --mode test",
    "dev:prod": "vite --open --mode production",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build  --mode production",
    "build:test": "vue-tsc --noEmit --skipLibCheck && vite build --mode test",
    "preview": "vite preview --open --port 9999",
    "type-check": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint src --fix ",
    "lint-staged": "lint-staged --no-stash"
  },
  "dependencies": {
    "@iconify/utils": "^2.1.30",
    "@tanstack/vue-query": "^5.51.21",
    "@vueuse/components": "^10.11.1",
    "@vueuse/core": "^10.11.1",
    "@vueuse/motion": "^2.2.3",
    "ant-design-vue": "^4.2.3",
    "axios": "^1.7.3",
    "dayjs": "^1.11.12",
    "echarts": "^5.5.1",
    "gsap": "^3.12.5",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "pinia": "^2.2.1",
    "store2": "^2.14.3",
    "vue": "^3.4.37",
    "vue-draggable-plus": "^0.5.3",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@faker-js/faker": "^8.4.1",
    "@iconify/json": "^2.2.235",
    "@iconify/types": "^2.0.0",
    "@iconify/vue": "^4.1.2",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.15",
    "@vitejs/plugin-legacy": "^5.4.1",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "eslint": "^9.9.0",
    "eslint-plugin-vue": "^9.27.0",
    "lint-staged": "^15.2.8",
    "sass": "^1.77.8",
    "simple-git-hooks": "^2.11.1",
    "terser": "^5.31.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.1",
    "unocss": "^0.61.9",
    "unplugin-auto-import": "^0.18.2",
    "unplugin-vue-components": "^0.27.3",
    "vite": "^5.4.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-fake-server": "^2.1.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pwa": "^0.20.1",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.29"
  },
  "engines": {
    "node": ">=18.12.0",
    "pnpm": ">=8.7.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm type-check && pnpm lint-staged"
  }
}
