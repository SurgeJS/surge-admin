{
  "name": "simple-admin",
  "private": true,
  "author": "SongPeng",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build:prod": "vue-tsc --noEmit --skipLibCheck && vite build  --mode production",
    "build:test": "vue-tsc --noEmit --skipLibCheck && vite build --mode test",
    "preview": "vite preview --open --port 9999",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint src --fix --ext .ts,.tsx,.vue,.js,.jsx",
    "lint-staged": "lint-staged --no-stash"
  },
  "dependencies": {
    "@alova/scene-vue": "^1.4.5",
    "@iconify/utils": "^2.1.22",
    "@vueuse/components": "^10.9.0",
    "@vueuse/core": "^10.9.0",
    "alova": "^2.18.0",
    "ant-design-vue": "^4.1.2",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "print-js": "^1.6.0",
    "qs": "^6.11.2",
    "store2": "^2.14.2",
    "vue": "^3.4.21",
    "vue-draggable-plus": "^0.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@iconify/json": "^2.2.196",
    "@iconify/vue": "^4.1.1",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.19",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@unocss/preset-icons": "0.59.0-beta.1",
    "@unocss/transformer-directives": "^0.58.8",
    "@vitejs/plugin-legacy": "^5.3.2",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "eslint": "^8.56.0",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-vue": "^9.20.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "sass": "^1.71.1",
    "terser": "^5.27.1",
    "typescript": "^5.4.3",
    "unocss": "^0.58.8",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.2.6",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-fake-server": "^2.1.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pwa": "^0.19.7",
    "vue-eslint-parser": "^9.4.2",
    "vue-tsc": "^2.0.6"
  },
  "lint-staged": {
    "*.{vue,js,ts,tsx,jsx}": [
      "eslint --fix",
      "git add"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.1.0"
  }
}
