{
  "name": "simple-admin",
  "private": true,
  "author": "SongPeng",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "dev:test": "vite --open --mode test",
    "dev:prod": "vite --open --mode production",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build  --mode production",
    "build:test": "vue-tsc --noEmit --skipLibCheck && vite build --mode test",
    "preview": "vite preview --open --port 9999",
    "type-check": "vue-tsc --noEmit --skipLibCheck",
    "lint": "eslint src --fix ",
    "lint-staged": "lint-staged --no-stash",
    "commit": "git add . && git cz",
    "prepare": "husky"
  },
  "dependencies": {
    "@iconify/utils": "^2.1.25",
    "@tanstack/vue-query": "^5.51.9",
    "@vueuse/components": "^10.11.0",
    "@vueuse/core": "^10.11.0",
    "@vueuse/motion": "^2.1.0",
    "ag-grid-community": "^32.0.2",
    "ag-grid-vue3": "^32.0.2",
    "ant-design-vue": "^4.2.3",
    "axios": "^1.7.2",
    "dayjs": "^1.11.11",
    "echarts": "^5.5.0",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "print-js": "^1.6.0",
    "store2": "^2.14.3",
    "vue": "^3.4.31",
    "vue-draggable-plus": "^0.4.1",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.3.0",
    "@faker-js/faker": "^8.4.1",
    "@iconify/json": "^2.2.214",
    "@iconify/types": "^2.0.0",
    "@iconify/vue": "^4.1.2",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.12.12",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-legacy": "^5.4.1",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vitejs/plugin-vue-jsx": "^4.0.0",
    "commitizen": "^4.3.0",
    "cz-git": "^1.9.3",
    "eslint": "^9.3.0",
    "eslint-plugin-vue": "^9.26.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "sass": "^1.77.2",
    "terser": "^5.31.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.11.0",
    "unocss": "^0.61.3",
    "unplugin-auto-import": "^0.17.6",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^5.3.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-fake-server": "^2.1.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pwa": "^0.19.8",
    "vue-eslint-parser": "^9.4.2",
    "vue-tsc": "^2.0.24"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.1.0"
  },
  "lint-staged": {
    "*.{vue,js,ts,tsx,jsx}": "eslint src --fix"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
